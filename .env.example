# Azure AD / Dataverse server-side credentials (no VITE_ prefix — never bundled to browser)
TENANT_ID=your-dataverse-tenant-id
CLIENT_ID=your-dataverse-client-id
CLIENT_SECRET=your-dataverse-client-secret
TOKEN_SCOPE=https://your-org.crm6.dynamics.com/.default

# Supabase public credentials (VITE_ prefix — safe to expose in the browser bundle)
# Prod (Australia, ap-southeast-2): vklwppadgogepkeaizow
# Legacy dev: yfvvroesornchrxufwut
VITE_SUPABASE_URL=https://vklwppadgogepkeaizow.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Public site URL for social link previews (Open Graph / Twitter cards).
# Set to your production domain, e.g. https://emci.acce.org.au
# Leave empty in local dev — preview image paths fall back to relative URLs.
VITE_SITE_URL=https://emci.acce.org.au

# Cloudflare Turnstile site key (public — safe in browser bundle).
# Create a widget at https://dash.cloudflare.com → Turnstile; add emci.acce.org.au and localhost.
# Pair with Supabase Dashboard → Authentication → Attack Protection → Turnstile secret.
VITE_TURNSTILE_SITE_KEY=your-turnstile-site-key

# Emergency maintenance lockout (optional). When true, only acce_admin can access EMCI.
# Prefer toggling maintenance mode from Team Management (persists in Supabase).
# VITE_MAINTENANCE_MODE=true

# Post-invite redirect for the invite-user edge function (Supabase secret, not VITE_).
# Must match Supabase Dashboard → Authentication → URL Configuration (Site URL + Redirect URLs).
# Deploy with: supabase secrets set APP_SITE_URL=https://emci.acce.org.au

# OpenAI — stored as a Supabase Edge Function SECRET (NOT in this file / browser bundle).
# Deploy with: supabase secrets set OPENAI_API_KEY=sk-proj-...
# The analyze-student edge function reads this via Deno.env.get("OPENAI_API_KEY").
